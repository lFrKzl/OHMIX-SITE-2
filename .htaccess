<IfModule mod_rewrite.c>
RewriteEngine On

# 1. Quebra o loop infinito de redirecionamento interno do servidor
RewriteCond %{ENV:REDIRECT_STATUS} 200
RewriteRule ^ - [L]

# 2. Encaminha arquivos pesados e de codigo (scripts, asstes, imagens) transparentemente para a pasta dist
RewriteCond %{REQUEST_URI} \.(js|css|json|png|jpg|jpeg|gif|svg|ico)$ [NC]
RewriteRule ^(.*)$ /dist/$1 [L]

# 3. Todo restanto do site (incluindo rotas do React e a entrada principal) sao enviados pro index do vite
RewriteRule ^(.*)$ /dist/index.html [L]
</IfModule>
